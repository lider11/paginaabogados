{
  "name": "lexiuridicus",
  "private": true,
  "version": "1.0.0",
  "description": "Despliegue raíz de Lexiuridicus",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "build": "npm --prefix frontend run build && node scripts/sync-frontend-to-public.js",
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "verify:deploy": "bash scripts/post-deploy-verify.sh",
    "deploy:production": "bash scripts/deploy-production.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
